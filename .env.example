# ==============================================================
# PoomSchool(품스쿨) MCP Server - 환경변수 예시
# 운영 환경에서는 아래 값을 반드시 실제 값으로 교체해야 합니다.
# ==============================================================

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# 공개 도메인 (Placeholder - 운영자가 반드시 교체)
PUBLIC_BASE_URL=https://<PUBLIC_DOMAIN>

# --------------------------------------------------------------
# AI Provider
# --------------------------------------------------------------
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
AI_TIMEOUT_MS=2500

# --------------------------------------------------------------
# Database
# --------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/poomschool_dev?schema=public
ANALYSIS_CACHE_ENABLED=true
ANALYSIS_CACHE_TTL_SECONDS=900

# --------------------------------------------------------------
# OAuth 2.1 Resource Server (Placeholder - 운영자가 반드시 교체)
# --------------------------------------------------------------
OAUTH_ISSUER=https://<OAUTH_ISSUER_DOMAIN>
OAUTH_AUDIENCE=https://<PUBLIC_DOMAIN>/mcp
OAUTH_JWKS_URL=https://<OAUTH_ISSUER_DOMAIN>/.well-known/jwks.json

# --------------------------------------------------------------
# Security
# --------------------------------------------------------------
ALLOWED_ORIGINS=https://playmcp.kakao.com
ALLOW_MISSING_ORIGIN=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# --------------------------------------------------------------
# 개발 전용 - production 에서는 절대 true로 설정하지 않습니다.
# --------------------------------------------------------------
AUTH_DISABLED=false
DEV_USER_SUB=local-test-user

# --------------------------------------------------------------
# Logging
# --------------------------------------------------------------
LOG_LEVEL=info
